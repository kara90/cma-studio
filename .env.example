# ─────────────────────────────────────────────────────────────
# CMA Studio v1.2 — environment
# Copy to .env.local and fill in. Nothing here is a user's Fal key —
# users supply their own Fal token at runtime (BYOK, stored only in
# their browser). These vars are for the platform itself.
# ─────────────────────────────────────────────────────────────

# Supabase — student entrance firewall (auth). Public anon key is safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER SECRET — used only by the Stripe webhook to write entitlement into a
# user's app_metadata. Bypasses RLS. NEVER expose to the client / never prefix
# with NEXT_PUBLIC. (Supabase → Project Settings → API → service_role key.)
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe billing (server secrets) ──
# Stripe → Developers → API keys (use the Cinemaster Academy account).
STRIPE_SECRET_KEY=
# Stripe → Developers → Webhooks → your /api/stripe/webhook endpoint signing secret.
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs (Stripe → Products). One price per tier + cycle.
STRIPE_PRICE_STUDENT_YEARLY=
STRIPE_PRICE_STUDENT_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
# Extension add-on Price IDs (monthly recurring).
STRIPE_PRICE_EXT=
STRIPE_PRICE_EXT_PLUS=
# Absolute site URL for Checkout success/cancel redirects (e.g. https://studio.cinemasteracademy.com).
NEXT_PUBLIC_SITE_URL=

# ── Cloudflare Turnstile (bot / scammer protection on login + signup) ──
# Public SITE key (safe to expose, inlined at build). Create a widget at
# Cloudflare → Turnstile. Leave blank in dev to use Cloudflare's always-pass TEST
# key automatically. The matching SECRET key is NOT set here — paste it into
# Supabase → Authentication → Attack Protection → enable CAPTCHA → Turnstile,
# where Supabase verifies the token server-side before creating a session.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Academy gate — comma-separated email domains allowed into the workspace.
# Example: cinemasteracademy.com,students.cinemasteracademy.com
# Blank allowlist FAILS CLOSED in production (denies everyone) and is only
# permissive in local dev. Auth itself is enforced server-side (proxy.ts +
# verifyAccess); a blank Supabase config in production locks the tool down.
NEXT_PUBLIC_ACADEMY_ALLOWED_DOMAINS=

# Per-user subscription enforcement. Set to "true" once plans are provisioned
# into each user's Supabase app_metadata.cma_plan (e.g. via a Stripe webhook);
# then /api/generate returns 402 for users without an active plan.
CMA_REQUIRE_ENTITLEMENT=false

# Fal render tier: "standard" (max quality, default) or "fast" (cheaper/lower latency).
# Users still pay with THEIR own key; this only picks the model slug.
FAL_RENDER_TIER=standard

# DEV ONLY — set to 1 in .env.local to use the workspace without Supabase wired
# up. Must be ABSENT in production; combined with NODE_ENV it keeps a
# misconfigured deploy failing closed. Never set this on Cloudflare Pages.
# NEXT_PUBLIC_CMA_ALLOW_DEV_BYPASS=1

# NOTE: NEXT_PUBLIC_* vars are inlined at BUILD time. On Cloudflare Pages,
# populate NEXT_PUBLIC_SUPABASE_URL/ANON_KEY (and academy domains) in the
# Production build environment so auth + the CSP connect-src are correct.
